<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <servlet>
        <servlet-name>HomeJsp</servlet-name>
        <jsp-file>/WEB-INF/jsp/home.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeJsp</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ListingsJsp</servlet-name>
        <jsp-file>/WEB-INF/jsp/listings/listings.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>ListingsJsp</servlet-name>
        <url-pattern>/listings</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginJsp</servlet-name>
        <jsp-file>/WEB-INF/jsp/auth/login.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginJsp</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutJsp</servlet-name>
        <jsp-file>/WEB-INF/jsp/auth/logout.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutJsp</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SignupJsp</servlet-name>
        <jsp-file>/WEB-INF/jsp/auth/signup.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>SignupJsp</servlet-name>
        <url-pattern>/signup</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminJsp</servlet-name>
        <jsp-file>/WEB-INF/jsp/admin-page.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminJsp</servlet-name>
        <url-pattern>/admin</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CreateListingJsp</servlet-name>
        <jsp-file>/WEB-INF/jsp/listings/create-listing.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>CreateListingJsp</servlet-name>
        <url-pattern>/create-listing</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MyListingsJsp</servlet-name>
        <jsp-file>/WEB-INF/jsp/listings/my-listings.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>MyListingsJsp</servlet-name>
        <url-pattern>/my-listings</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditListingJsp</servlet-name>
        <jsp-file>/WEB-INF/jsp/listings/edit-listing.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditListingJsp</servlet-name>
        <url-pattern>/edit-listing</url-pattern>
    </servlet-mapping>
    <servlet>
    	<servlet-name>DeleteAccountJsp</servlet-name>
    	<jsp-file>/WEB-INF/jsp/auth/delete-account.jsp</jsp-file>
	</servlet>
	<servlet-mapping>
    	<servlet-name>DeleteAccountJsp</servlet-name>
    	<url-pattern>/delete-account</url-pattern>
	</servlet-mapping>
	<servlet>
    	<servlet-name>MessagesJsp</servlet-name>
    	<jsp-file>/WEB-INF/jsp/messages/router.jsp</jsp-file>
	</servlet>
		<servlet-mapping>
    	<servlet-name>MessagesJsp</servlet-name>
    	<url-pattern>/messages</url-pattern>
	</servlet-mapping>

	<servlet>
    <servlet-name>InboxJsp</servlet-name>
    <jsp-file>/WEB-INF/jsp/messages/inbox.jsp</jsp-file>
</servlet>
<servlet-mapping>
    <servlet-name>InboxJsp</servlet-name>
    <url-pattern>/inbox</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>SubmitReportJsp</servlet-name>
    <jsp-file>/WEB-INF/jsp/reports/submit-report.jsp</jsp-file>
</servlet>
<servlet-mapping>
    <servlet-name>SubmitReportJsp</servlet-name>
    <url-pattern>/submit-report</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>AdminReportsJsp</servlet-name>
    <jsp-file>/WEB-INF/jsp/admin-reports.jsp</jsp-file>
</servlet>
<servlet-mapping>
    <servlet-name>AdminReportsJsp</servlet-name>
    <url-pattern>/admin-reports</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>ConfirmSaleJsp</servlet-name>
    <jsp-file>/WEB-INF/jsp/listings/confirm-sale.jsp</jsp-file>
</servlet>
<servlet-mapping>
    <servlet-name>ConfirmSaleJsp</servlet-name>
    <url-pattern>/confirm-sale</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>MyTransactionsJsp</servlet-name>
    <jsp-file>/WEB-INF/jsp/listings/my-transactions.jsp</jsp-file>
</servlet>
<servlet-mapping>
    <servlet-name>MyTransactionsJsp</servlet-name>
    <url-pattern>/my-transactions</url-pattern>
</servlet-mapping>
</web-app>